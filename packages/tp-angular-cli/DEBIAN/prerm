#!/bin/bash
set -e

if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    export NVM_DIR="/opt/nvm"
    if [ -s "$NVM_DIR/nvm.sh" ]; then
        echo "Removing Angular CLI..."
        \. "$NVM_DIR/nvm.sh" 2>/dev/null || true
        npm uninstall -g @angular/cli 2>/dev/null || true
    fi
fi

exit 0
