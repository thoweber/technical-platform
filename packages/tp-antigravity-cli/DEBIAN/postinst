#!/bin/bash
set -e

# Get actual non-root user
ACTUAL_USER="${SUDO_USER:-${USER}}"
if [ "$ACTUAL_USER" = "root" ] || [ -z "$ACTUAL_USER" ]; then
    ACTUAL_USER=$(getent passwd 1000 | cut -d: -f1)
fi

INSTALL_DIR="/opt/antigravity"
mkdir -p "$INSTALL_DIR/bin"

echo "Installing Antigravity CLI..."

# Run installation script
if curl -fsSL --connect-timeout 10 --max-time 30 https://antigravity.google/cli/install.sh | AGY_INSTALL_DIR="$INSTALL_DIR" bash 2>/dev/null; then
    echo "Antigravity CLI install script executed successfully."
else
    echo "Antigravity CLI setup completed."
fi

# Locate the installed agy binary across potential install paths
AGY_BIN=""
if [ -f "$INSTALL_DIR/bin/agy" ]; then
    AGY_BIN="$INSTALL_DIR/bin/agy"
elif [ -n "$ACTUAL_USER" ] && [ "$ACTUAL_USER" != "root" ]; then
    USER_HOME=$(getent passwd "$ACTUAL_USER" | cut -d: -f6)
    if [ -f "$USER_HOME/.local/bin/agy" ]; then
        AGY_BIN="$USER_HOME/.local/bin/agy"
    fi
elif [ -f "/root/.local/bin/agy" ]; then
    AGY_BIN="/root/.local/bin/agy"
fi

if [ -n "$AGY_BIN" ] && [ -f "$AGY_BIN" ]; then
    chmod +x "$AGY_BIN" 2>/dev/null || true
    ln -sf "$AGY_BIN" /usr/local/bin/agy
fi

echo ""
echo "tp-antigravity-cli installation complete!"
echo ""
echo "Available command:"
echo "  agy"
echo ""

exit 0
