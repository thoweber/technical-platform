#!/bin/bash
set -e

# Get the user who invoked sudo (or current user if not using sudo)
ACTUAL_USER="${SUDO_USER:-${USER}}"

# If we're root and no SUDO_USER is set, try to find the default user
if [ "$ACTUAL_USER" = "root" ] || [ -z "$ACTUAL_USER" ]; then
    ACTUAL_USER=$(getent passwd 1000 | cut -d: -f1)
fi

# Install IntelliJ IDEA Ultimate via snapd
if command -v snap > /dev/null 2>&1; then
    echo "Installing IntelliJ IDEA Ultimate via snap..."
    snap install intellij-idea-ultimate --classic || echo "Note: snap installation will complete when snapd service is active"
else
    echo "Warning: snap command not found. Please ensure snapd is installed."
fi

# Configure Noto Color Emoji fallback font
if [ -n "$ACTUAL_USER" ] && [ "$ACTUAL_USER" != "root" ]; then
    USER_HOME=$(getent passwd "$ACTUAL_USER" | cut -d: -f6)
    if [ -n "$USER_HOME" ] && [ -d "$USER_HOME" ]; then
        echo "Configuring IntelliJ IDEA settings for '$ACTUAL_USER'..."
        
        JB_DIR="$USER_HOME/.config/JetBrains"
        mkdir -p "$JB_DIR"

        shopt -s nullglob
        IDEA_DIRS=("$JB_DIR"/IntelliJIdea* "$JB_DIR"/IdeaIC*)
        shopt -u nullglob

        if [ ${#IDEA_DIRS[@]} -eq 0 ]; then
            IDEA_DIRS=("$JB_DIR/IntelliJIdea2026.2")
        fi

        for idea_dir in "${IDEA_DIRS[@]}"; do
            opts_dir="$idea_dir/options"
            mkdir -p "$opts_dir"

            # Configure Noto Color Emoji fallback font in editor-font.xml (Component: DefaultFont)
            font_file="$opts_dir/editor-font.xml"
            if [ ! -f "$font_file" ]; then
                cat > "$font_file" << 'EOF'
<application>
  <component name="DefaultFont">
    <option name="VERSION" value="1" />
    <option name="SECONDARY_FONT_FAMILY" value="Noto Color Emoji" />
  </component>
</application>
EOF
            else
                if ! grep -q 'SECONDARY_FONT_FAMILY' "$font_file"; then
                    if grep -q '<component name="DefaultFont">' "$font_file"; then
                        sed -i '/<component name="DefaultFont">/a \    <option name="SECONDARY_FONT_FAMILY" value="Noto Color Emoji" />' "$font_file" 2>/dev/null || true
                    fi
                fi
            fi
        done

        chown -R "$ACTUAL_USER:$ACTUAL_USER" "$JB_DIR" 2>/dev/null || true
    fi
fi

# Run interop configuration check if both tools are present
if [ -f /etc/profile.d/tp-intellij-agy-interop.sh ]; then
    bash /etc/profile.d/tp-intellij-agy-interop.sh 2>/dev/null || true
fi



echo ""
echo "tp-intellij-idea installation complete!"
echo ""
echo "Available command:"
echo "  intellij-idea-ultimate"
echo ""

exit 0
