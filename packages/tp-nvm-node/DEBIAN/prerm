#!/bin/bash
set -e

if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    echo "Uninstalling all NVM-managed Node.js versions and removing NVM installation..."
    export NVM_DIR="/opt/nvm"
    
    if [ -d "$NVM_DIR" ]; then
        rm -rf "$NVM_DIR" 2>/dev/null || true
    fi

    rm -f /etc/profile.d/nvm.sh 2>/dev/null || true
fi

exit 0
