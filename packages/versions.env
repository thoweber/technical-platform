# ==============================================================================
# TECHNICAL PLATFORM - UPSTREAM TOOL & DEBIAN PACKAGE VERSIONS
# ==============================================================================
# This file centralizes all version definitions for technical-platform packages.
# Edit the variables below, then run `scripts/update-versions.sh` to propagate
# version changes across all Debian control files, postinst scripts, and docs.
#
# Renovate Bot automatically monitors the `# renovate:` annotations below
# and creates Pull Requests when upstream releases are published.

# ------------------------------------------------------------------------------
# JAVA (tp-sdkman-java)
# ------------------------------------------------------------------------------
# Upstream SDKMAN Java candidate version (e.g. 25-tem, 21.0.2-tem)
# How to check for updates:
#   1. Run `sdk list java` inside a shell with SDKMAN installed.
#   2. Or query API: curl -s "https://api.sdkman.io/2/candidates/java/ubuntu/x86_64/versions/list"
# renovate: datasource=github-releases depName=adoptium/temurin25-binaries
TP_JAVA_VERSION="25-tem"
TP_SDKMAN_JAVA_PKG_VERSION="1.0.1"

# ------------------------------------------------------------------------------
# NODE.JS & NVM (tp-nvm-node)
# ------------------------------------------------------------------------------
# Upstream NVM release installer version
# How to check for updates: https://github.com/nvm-sh/nvm/releases
# renovate: datasource=github-releases depName=nvm-sh/nvm
TP_NVM_VERSION="0.39.7"

# Upstream default Node.js LTS major version (e.g. 24, 22)
# How to check for updates: https://nodejs.org/en/about/previous-releases
# renovate: datasource=node-v8 depName=node
TP_NODE_VERSION="24"
TP_NVM_NODE_PKG_VERSION="1.0.2"

# ------------------------------------------------------------------------------
# ANGULAR CLI (tp-angular-cli)
# ------------------------------------------------------------------------------
# Upstream Angular CLI package spec (e.g. @angular/cli)
# How to check for updates: npm view @angular/cli version
# renovate: datasource=npm depName=@angular/cli
TP_ANGULAR_CLI_VERSION="@angular/cli"
TP_ANGULAR_CLI_PKG_VERSION="1.0.1"

# ------------------------------------------------------------------------------
# DOCKER CE (tp-docker)
# ------------------------------------------------------------------------------
# Package version for tp-docker
TP_DOCKER_PKG_VERSION="1.0.1"

# ------------------------------------------------------------------------------
# INTELLIJ IDEA (tp-intellij-idea)
# ------------------------------------------------------------------------------
# Config directory version matching string (e.g. IntelliJIdea2026.2)
# How to check for updates: https://data.services.jetbrains.com/products/releases?code=IIU&latest=true&type=release
TP_INTELLIJ_CONFIG_VER="IntelliJIdea2026.2"
TP_INTELLIJ_IDEA_PKG_VERSION="1.0.17"

# ------------------------------------------------------------------------------
# ANTIGRAVITY CLI (tp-antigravity-cli)
# ------------------------------------------------------------------------------
# Package version for tp-antigravity-cli
TP_ANTIGRAVITY_CLI_PKG_VERSION="1.0.9"

# ------------------------------------------------------------------------------
# INTELLIJ & ANTIGRAVITY MCP INTEROP (tp-intellij-agy-interop)
# ------------------------------------------------------------------------------
# MCP Server configuration key and URL
TP_INTEROP_MCP_KEY="wsl-isolated-intellij-idea-mcp"
TP_INTEROP_MCP_URL="http://127.0.0.1:63343/debugger-mcp/sse"
TP_INTEROP_PKG_VERSION="1.0.3"
